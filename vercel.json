{
  "version": 2,
  "builds": [
    {
      "src": "api/info.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "50mb" }
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/info", "dest": "/api/info.py" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "functions": {
    "api/info.py": {
      "maxDuration": 30
    }
  }
}
